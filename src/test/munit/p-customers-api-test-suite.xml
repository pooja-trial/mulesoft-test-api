    <munit:config name="p-customers-api-test-suite.xml" />

    <!-- TEST 1: New customer INSERT success -->
    <munit:test name="customers-upsert-flow-single-insert-success"
        doc:name="Insert New Customer — HTTP 200 Success"
        doc:description="New customer not in DB is inserted, returns Success and HTTP 200">
        <munit:behavior>
            <munit:set-event doc:name="Set payload — single new customer" doc:id="33f5d42c-91c7-4d52-bd5c-add8c537e953" >
				<munit:payload value='#[output application/json&#10;---&#10;[{customerEmail: "newuser@test.com", firstName: "Jane", lastName: "Smith", contactNumber: "555-0001", address: "100 Main St", location: "USA"}]]' encoding="UTF-8" mediaType="application/json" />
			</munit:set-event>
			<!-- <munit-tools:set-event doc:name="Set payload — single new customer">
                <munit-tools:payload mediaType="application/json"
                    value='#[[{customerEmail: "newuser@test.com", firstName: "Jane", lastName: "Smith", contactNumber: "555-0001", address: "100 Main St", location: "USA"}]]' />
            </munit-tools:set-event> -->
            <munit-tools:mock-when processor="snowflake:select" doc:name="Mock DB query-single — null (not found)">
                <munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Snowflake_Config" attributeName="config-ref" />
				</munit-tools:with-attributes>
				<munit-tools:then-return >
					<munit-tools:variables >
						<munit-tools:variable key="existingCustomer" value="#[null]" mediaType="application/java" />
					</munit-tools:variables>
				</munit-tools:then-return>
            </munit-tools:mock-when>
            <munit-tools:mock-when processor="snowflake:insert" doc:name="Mock db:insert — 1 affected row">
                <munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Snowflake_Config" attributeName="config-ref" />
				</munit-tools:with-attributes>
				<munit-tools:then-return>
                    <munit-tools:payload value="#[1]" mediaType="application/java"/>
                </munit-tools:then-return>
            </munit-tools:mock-when>
            <munit-tools:mock-when processor="email:send" doc:name="Mock email:send — not called">
                <munit-tools:then-return/>
            </munit-tools:mock-when>
        </munit:behavior>
        <munit:execution>
            <flow-ref name="customers-upsert-flow" doc:name="Run customers-upsert-flow"/>
        </munit:execution>
        <munit:validation>
            <munit-tools:assert-that expression="#[sizeOf(payload)]" is="#[MunitTools::equalTo(1)]" doc:name="Response has 1 record"/>
            <munit-tools:assert-that expression="#[payload..customerEmail[0]]" is="#[MunitTools::equalTo('newuser@test.com')]" doc:name="customerEmail correct"/>
            <munit-tools:assert-that expression="#[payload..status[0]]" is="#[MunitTools::equalTo('Success')]" doc:name="status = Success"/>
            <munit-tools:assert-that expression="#[payload..message[0]]" is="#[MunitTools::equalTo('')]" doc:name="message empty on success"/>
            <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]" doc:name="HTTP status 200"/>
            <munit-tools:verify-call processor="snowflake:insert" doc:name="INSERT called once" times="1">
				<munit-tools:with-attributes >
					<munit-tools:with-attribute whereValue="Snowflake_Config" attributeName="config-ref" />
				</munit-tools:with-attributes>
			</munit-tools:verify-call>
            <munit-tools:verify-call processor="email:send" doc:name="Email NOT sent" times="0"/>
        </munit:validation>
    </munit:test>

