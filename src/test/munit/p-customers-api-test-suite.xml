            <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]" doc:name="HTTP status 200"/>
            <munit-tools:verify-call processor="snowflake:insert" doc:name="INSERT called twice" times="2">
