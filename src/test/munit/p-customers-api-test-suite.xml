            <munit-tools:assert-that expression="#[payload..status[0]]" is="#[MunitTools::equalTo('Failure')]" doc:name="status = Failure"/>
            <munit-tools:assert-that expression="#[payload..customerEmail[0]]" is="#[MunitTools::equalTo('error@test.com')]" doc:name="customerEmail correct"/>
            <munit-tools:assert-that expression="#[vars.httpStatus]" is="#[MunitTools::equalTo(200)]" doc:name="HTTP status 200"/>
